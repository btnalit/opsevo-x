# Opsevo-x 环境变量配置

# 服务器配置
PORT=8080                    # 外部访问端口（Docker 映射）
NODE_ENV=production          # 运行环境: development | production

# 日志配置
LOG_LEVEL=info               # 日志级别: debug | info | warn | error

# Syslog 配置
SYSLOG_PORT=514              # Syslog UDP 外部映射端口

# Nginx 配置（仅在使用 with-nginx profile 时需要）
NGINX_HTTP_PORT=80           # Nginx HTTP 端口
NGINX_HTTPS_PORT=443         # Nginx HTTPS 端口

# Skill 系统配置
# SKILL_SYSTEM_ENABLED=true  # 是否启用 Skill 系统，默认 true

# --- PostgreSQL 配置 ---
PG_USER=opsevo                # PostgreSQL 用户名
PG_PASSWORD=changeme          # PostgreSQL 密码（必填，请修改为安全密码）
PG_DATABASE=opsevo            # PostgreSQL 数据库名
PG_PORT=5432                  # PostgreSQL 外部映射端口
PG_POOL_MIN=2                 # 连接池最小连接数
PG_POOL_MAX=10                # 连接池最大连接数
PG_IDLE_TIMEOUT=30000         # 连接池空闲超时（毫秒）

# --- 内部服务通信 ---
INTERNAL_API_KEY=changeme-internal-key  # Python Core 内部 API 认证密钥（请修改为安全密钥）
PYTHON_CORE_URL=http://python-core:8001  # Python Core 服务地址（Docker 内部）
PYTHON_CORE_PORT=8001         # Python Core 外部映射端口

# --- Embedding 模型配置 ---
EMBEDDING_MODEL=all-MiniLM-L6-v2  # 本地嵌入模型名称
# EMBEDDING_REMOTE_URL=         # 远程 Embedding API 地址（可选，设置后使用远程模式）
# EMBEDDING_REMOTE_API_KEY=     # 远程 Embedding API 密钥

# --- AI & LLM 配置 ---

# AI 供应商: openai | gemini | qwen | zhipu
AI_PROVIDER=gemini
AI_MODEL_NAME=gemini-1.5-flash

# OpenAI 配置
OPENAI_API_KEY=your-openai-key
# OPENAI_BASE_URL=https://api.openai.com/v1

# Gemini 配置
GEMINI_API_KEY=your-gemini-key

# Qwen (阿里) 配置
QWEN_API_KEY=your-qwen-key

# Zhipu (智谱) 配置
ZHIPU_API_KEY=your-zhipu-key

# --- RAG & Embedding 配置 ---

# Embedding 供应商 (默认同 AI_PROVIDER)
# EMBEDDING_PROVIDER=zhipu
# EMBEDDING_MODEL_NAME=embedding-2

# Reranker 配置（可选，用于增强 RAG 找回精度）
# RERANK_API_KEY=your-api-key
# RERANK_BASE_URL=https://api.example.com/v1
# RERANK_MODEL_NAME=bge-reranker-v2-m3
# RERANK_TOP_K=5
# RERANK_THRESHOLD=0.5
# RERANK_TIMEOUT=30000
