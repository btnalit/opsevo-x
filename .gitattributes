# Auto detect text files and perform LF normalization
* text=auto

# Shell scripts must use LF line endings
*.sh text eol=lf
docker-entrypoint.sh text eol=lf

# Batch files use CRLF
*.bat text eol=crlf
*.cmd text eol=crlf

# Binary files
*.png binary
*.jpg binary
*.jpeg binary
*.gif binary
*.ico binary
*.pdf binary
*.zip binary
*.tar binary
*.gz binary
