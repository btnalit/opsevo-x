# Dependencies
node_modules/
*/node_modules/

# Production builds
dist/
build/
*/dist/
*/build/

# Environment variables
.env
.env.local
.env.development.local
.env.test.local
.env.production.local

# Logs (use specific path to avoid blocking backend/logs/.gitkeep exception)
/logs/
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
lerna-debug.log*

# Runtime data
pids
*.pid
*.seed
*.pid.lock

# Coverage directory used by tools like istanbul
coverage/
*.lcov

# nyc test coverage
.nyc_output

# Dependency directories
jspm_packages/

# TypeScript cache
*.tsbuildinfo

# Optional npm cache directory
.npm

# Optional eslint cache
.eslintcache

# Optional REPL history
.node_repl_history

# Output of 'npm pack'
*.tgz

# Yarn Integrity file
.yarn-integrity

# parcel-bundler cache (https://parceljs.org/)
.cache
.parcel-cache

# Vite generated temporary files
*.mjs

# Next.js build output
.next

# Nuxt.js build / generate output
.nuxt

# Gatsby files
.cache/
public
!frontend/public/

# Storybook build outputs
.out
.storybook-out

# Temporary folders
tmp/
temp/

# Editor directories and files
.vscode/
.idea/
.kiro/
*.swp
*.swo
*~

# OS generated files
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
ehthumbs.db
Thumbs.db

# Database files
*.db
*.sqlite
*.sqlite3

# Configuration files with sensitive data
config/local.json
config/production.json

# SSL Certificates (keep .gitkeep)
certs/*
!certs/.gitkeep

# Legacy backends (kept locally for reference, excluded from git)
backend/
python-core/

# Code audit reports (generated files)
reports/
docs/

# Python Core runtime artifacts
**/__pycache__/
*.pyc
*.pyo
.pytest_cache/
.hypothesis/
python-core/.venv/
python-core/.env


# Backup files
*-bk
*.bak
*.backup

# Test artifacts (Jest migration temp dirs)
__test_vector_migrations_*
