{
  "name": "opsevo-x",
  "version": "4.0.0",
  "description": "OpsEvo-X — 泛化 AIOps 智能运维平台",
  "scripts": {
    "dev:backend": "cd opsevo-python && uvicorn src.opsevo.main:app --reload --port 3099",
    "dev:frontend": "cd frontend && npm run dev",
    "build:frontend": "cd frontend && npm run build",
    "test:backend": "cd opsevo-python && python -m pytest tests/ -v",
    "test:frontend": "cd frontend && npm test",
    "lint:frontend": "cd frontend && npm run lint"
  },
  "keywords": ["aiops", "intelligent-ops", "device-agnostic", "event-driven", "brain-loop"],
  "author": "Opsevo Team",
  "license": "Apache-2.0"
}
