# ============================================================
# Opsevo-X Python Backend — Environment Configuration
# Copy this file to .env and fill in your values
# ============================================================

# ── Server ────────────────────────────────────────────────────
PORT=3099
ENV=production
LOG_LEVEL=info

# ── Database (PostgreSQL + pgvector) ──────────────────────────
# Option 1: Full connection string
# DATABASE_URL=postgresql://opsevo:opsevo123@localhost:5432/opsevo
# Option 2: Individual components (auto-assembled if DATABASE_URL is empty)
PG_USER=opsevo
PG_PASSWORD=opsevo123
PG_HOST=localhost
PG_PORT=5432
PG_DATABASE=opsevo
PG_POOL_MIN=2
PG_POOL_MAX=10

# ── Security ──────────────────────────────────────────────────
JWT_SECRET=changeme-jwt-secret
INTERNAL_API_KEY=changeme-internal-key
ENCRYPTION_KEY=
AI_CRYPTO_SECRET_KEY=ai-ops-agent-secret-key-2024

# ── CORS ──────────────────────────────────────────────────────
CORS_ORIGINS=http://localhost:5173,http://localhost:3099

# ── AI Provider ───────────────────────────────────────────────
AI_PROVIDER=gemini
AI_MODEL_NAME=gemini-1.5-flash
GEMINI_API_KEY=
OPENAI_API_KEY=
OPENAI_BASE_URL=https://api.openai.com/v1
CLAUDE_API_KEY=
DEEPSEEK_API_KEY=
QWEN_API_KEY=
ZHIPU_API_KEY=

# ── Embedding ─────────────────────────────────────────────────
EMBEDDING_MODEL=all-MiniLM-L6-v2
EMBEDDING_REMOTE_URL=
EMBEDDING_REMOTE_API_KEY=

# ── Protocol Ports ────────────────────────────────────────────
SYSLOG_PORT=514
SNMP_TRAP_PORT=162

# ── Brain (Autonomous OODA) ──────────────────────────────────
BRAIN_ENABLED=false
BRAIN_TICK_INTERVAL=30
BRAIN_TOKEN_BUDGET=500000

# ── MCP Integration ──────────────────────────────────────────
MCP_SERVER_ENABLED=true

# ── Skill System ─────────────────────────────────────────────
SKILL_SYSTEM_ENABLED=true
SKILLS_DIR=data/ai-ops/skills
